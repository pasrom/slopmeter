{
  "name": "codegraph",
  "private": true,
  "packageManager": "bun@1.3.3",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=codegraph-cli",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "check": "turbo run typecheck build",
    "start": "turbo run start --filter=codegraph-cli"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.7.2"
  }
}
