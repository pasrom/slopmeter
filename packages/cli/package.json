{
  "name": "slopmeter",
  "version": "0.2.0",
  "description": "CLI for generating yearly usage heatmaps for Claude Code, Codex, and Open Code.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "author": "Jean P.D. Meijer",
  "homepage": "https://github.com/JeanMeijer/slopmeter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeanMeijer/slopmeter.git"
  },
  "bugs": {
    "url": "https://github.com/JeanMeijer/slopmeter/issues"
  },
  "keywords": [
    "cli",
    "heatmap",
    "usage",
    "codex",
    "claude-code",
    "opencode"
  ],
  "bin": {
    "slopmeter": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "tsup && tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run build",
    "start": "node dist/cli.js",
    "prepublishOnly": "bun run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "latest",
    "eslint": "^9.39.2",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.50.1"
  },
  "dependencies": {
    "ora": "^9.3.0",
    "ow": "^3.1.1",
    "sharp": "^0.34.5",
    "svg-builder": "^3.0.4"
  }
}
